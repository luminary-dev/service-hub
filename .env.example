# API gateway origin — target of the /api/* rewrite and of server-side fetches.
GATEWAY_URL=http://localhost:4000

# Shared JWT secret for verifying the sh_session cookie (signed by
# identity-service). Must match the gateway and identity-service.
AUTH_SECRET=dev-only-secret

# Canonical public origin for sitemap/robots/OG URLs (optional).
# NEXT_PUBLIC_SITE_URL=

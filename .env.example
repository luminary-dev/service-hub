# API gateway origin — target of the /api/* rewrite and of server-side fetches.
GATEWAY_URL=http://localhost:4000

# Shared JWT secret for verifying the sh_session cookie (signed by
# identity-service). Must match the gateway and identity-service.
AUTH_SECRET=dev-only-secret

# Canonical public origin for sitemap/robots/OG URLs (optional).
# NEXT_PUBLIC_SITE_URL=

# Cloudflare Turnstile public site key (#633) — optional bot protection on the
# signup forms. Unset (the default) → no widget is rendered and registration
# submits as before. When set, the signup forms show the Turnstile challenge and
# include its token in the register request; pair it with TURNSTILE_SECRET_KEY on
# identity-service (both are needed to actually enforce the check).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Feature flags (#675) — optional. Both unset (the default) → src/lib/flags.ts is
# a no-op and every flag falls back to its coded default, so the app runs exactly
# as today. To try flags locally, start the flag service
# (`docker compose --profile flags up -d unleash`), create a Frontend API token
# in the admin UI at http://localhost:4242, then set both here. If you set
# UNLEASH_FRONTEND_TOKEN BEFORE bringing the flag service up, compose also seeds
# it into Unleash (INIT_FRONTEND_API_TOKENS) so you can skip the UI step. See
# docs/OPERATIONS.md → Feature flags.
# UNLEASH_URL=http://localhost:4242/api
# UNLEASH_FRONTEND_TOKEN=

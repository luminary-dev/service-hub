# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
services/*/coverage

# playwright browser e2e (#671): run artifacts, never committed
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
# lighthouse ci output
/.lighthouseci/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# database
prisma/dev.db
prisma/dev.db-journal

# user uploads (seed images under /seed are committed so production serves them)
/public/uploads/*
!/public/uploads/seed/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.prod.example

# database backups (#389): local snapshots + nightly log; host-local backup config
/backups/
.backup.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local image-generation output (source for public/images/categories/*)
/generated/

# macOS SwiftPM vendored sources
mobile/macos/**/xcshareddata/swiftpm/

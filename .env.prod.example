# Production environment for docker-compose.prod.yml.
# Copy to `.env` on the server and fill in. Required vars have NO default — the
# stack refuses to start without them (matches the app's AUTH_SECRET /
# INTERNAL_API_SECRET production guards). Generate secrets with:
#   openssl rand -base64 32
# If a hand-filled value contains $, #, quotes, or whitespace, double-quote it
# and escape for Compose's dotenv parser (\ → \\, " → \", $ → $$): unquoted
# values are truncated at " #" and $ is interpolated. The CD render
# (deploy.yml) applies this escaping automatically.

# --- Required ---
DOMAIN=baas.lk                 # public hostname (Caddy TLS)
WEB_ORIGIN=https://baas.lk     # public https origin — email links + CSRF + x-origin
AUTH_SECRET=                   # identity signs the session JWT; gateway + web verify it
INTERNAL_API_SECRET=           # service-to-service trust; gateway stamps it on upstream calls
POSTGRES_PASSWORD=             # Postgres superuser password (cluster admin + backups only)
# Per-service DB role passwords (#387): each DB service connects as its own
# least-privilege role (identity/provider/review/job/notification/search/
# trust_safety), owning only its own database. Generate with
# `openssl rand -hex 32` — these are interpolated into DATABASE_URLs, so they
# MUST be URL-safe (hex is; base64 is not: / + =).
# Fresh volume: roles are created on initdb (deploy/postgres-init.sh).
# Existing volume: run deploy/migrate-db-roles.sh ONCE — see docs/DEPLOYMENT.md
# (it also creates notification_db when the cluster predates the stateful
# notification-service).
# search_db (search & discovery RFC) additionally needs the PostGIS extension
# and the postgis/postgis compose image; migrate-db-roles.sh creates it (role +
# database + extension, superuser) — run it AFTER the image swap and BEFORE
# deploying the stack that starts search-service.
IDENTITY_DB_PASSWORD=
PROVIDER_DB_PASSWORD=
REVIEW_DB_PASSWORD=
JOB_DB_PASSWORD=
NOTIFICATION_DB_PASSWORD=
SEARCH_DB_PASSWORD=
TRUST_SAFETY_DB_PASSWORD=
# Redis AUTH (#387): protects the rate-limit windows + session-revocation list
# from any other container on the network. Also URL-interpolated → use hex.
REDIS_PASSWORD=

# Which published image tag to run. Prefer a commit SHA from the Deploy
# workflow (what CD pins here on every deploy — exact and rollback-friendly).
# "prod" tracks the latest fully-successful build (all 11 images are re-tagged
# together, only after every build succeeded), but a pull can race an
# in-flight deploy; pin the SHA when in doubt.
IMAGE_TAG=prod

# --- Optional (features degrade gracefully when unset) ---
# Trusted reverse-proxy hops in front of the api-gateway, for rate-limit client
# IP resolution (#201). Socket peer = hop 1; the Caddy→web→gateway chain is 2
# (the compose default). 0 disables XFF trust entirely. See docs/RATE_LIMITING.md.
TRUSTED_PROXY_HOPS=2
ACME_EMAIL=                    # Let's Encrypt account email; unset → admin@${DOMAIN} (an empty Caddyfile `email` arg would crash-loop Caddy, #387)
RESEND_API_KEY=                # transactional email; unset → emails only log to console
EMAIL_FROM=                    # e.g. "Baas.lk <noreply@baas.lk>" (must be on the verified domain)
# Social login (#398) — Google OAuth. Unset → the "Continue with Google" button
# redirects to /login?error=oauth_unavailable (password auth still works).
# Register the redirect URI ${WEB_ORIGIN}/api/auth/oauth/google/callback in the
# Google Cloud console.
GOOGLE_CLIENT_ID=              # Google Cloud OAuth 2.0 client id
GOOGLE_CLIENT_SECRET=          # Google Cloud OAuth 2.0 client secret
# Facebook Login (#398) — optional; unset → its button is disabled. Register
# redirect URI ${WEB_ORIGIN}/api/auth/oauth/facebook/callback in Meta for Developers.
FACEBOOK_CLIENT_ID=            # Meta app id (App ID)
FACEBOOK_CLIENT_SECRET=        # Meta app secret
# Uploads storage — precedence: R2 (all four) > local disk volumes.
# Cloudflare R2 (recommended: free tier, zero egress, private bucket).
# Unset all four → local disk volumes (which you must then back up).
R2_ENDPOINT=                   # https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=                     # e.g. luminary-baas-lk
R2_ACCESS_KEY_ID=              # R2 → Manage R2 API Tokens → S3-compatible credentials
R2_SECRET_ACCESS_KEY=
ANTHROPIC_API_KEY=             # chat assistant; unset → assistant returns 503 (disabled)
# NOTE: the nightly DB-backup config (BACKUP_R2_* offsite credentials +
# BACKUP_HEARTBEAT_URL, #389) is deliberately NOT in this file — CD re-renders
# this .env from GitHub secrets on every deploy. It lives in the host-local
# .backup.env (seeded by scripts/install-backup-cron.sh); see docs/BACKUPS.md.

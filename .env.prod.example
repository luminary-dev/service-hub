# Production environment for docker-compose.prod.yml.
# Copy to `.env` on the server and fill in. Required vars have NO default — the
# stack refuses to start without them (matches the app's AUTH_SECRET /
# INTERNAL_API_SECRET production guards). Generate secrets with:
#   openssl rand -base64 32

# --- Required ---
DOMAIN=baas.lk                 # public hostname (Caddy TLS)
WEB_ORIGIN=https://baas.lk     # public https origin — email links + CSRF + x-origin
AUTH_SECRET=                   # identity signs the session JWT; gateway + web verify it
INTERNAL_API_SECRET=           # service-to-service trust; gateway stamps it on upstream calls
POSTGRES_PASSWORD=             # Postgres superuser password (used in every DATABASE_URL)

# Which published image tag to run: a commit SHA from the Deploy workflow, or "prod".
IMAGE_TAG=prod

# --- Optional (features degrade gracefully when unset) ---
# Trusted reverse-proxy hops in front of the api-gateway, for rate-limit client
# IP resolution (#201). Socket peer = hop 1; the Caddy→web→gateway chain is 2
# (the compose default). 0 disables XFF trust entirely. See docs/RATE_LIMITING.md.
TRUSTED_PROXY_HOPS=2
ACME_EMAIL=                    # Let's Encrypt account email — cert-expiry notices
RESEND_API_KEY=                # transactional email; unset → emails only log to console
EMAIL_FROM=                    # e.g. "Baas.lk <noreply@baas.lk>" (must be on the verified domain)
# Social login (#398) — Google OAuth. Unset → the "Continue with Google" button
# redirects to /login?error=oauth_unavailable (password auth still works).
# Register the redirect URI ${WEB_ORIGIN}/api/auth/oauth/google/callback in the
# Google Cloud console.
GOOGLE_CLIENT_ID=              # Google Cloud OAuth 2.0 client id
GOOGLE_CLIENT_SECRET=          # Google Cloud OAuth 2.0 client secret
# Facebook Login (#405). Register the redirect URI
# ${WEB_ORIGIN}/api/auth/oauth/facebook/callback in the Meta app dashboard.
# Both unset → "Continue with Facebook" is hidden; password auth is unaffected.
FACEBOOK_CLIENT_ID=            # Meta app id
FACEBOOK_CLIENT_SECRET=        # Meta app secret
# Uploads storage — precedence: R2 (all four) > local disk volumes.
# Cloudflare R2 (recommended: free tier, zero egress, private bucket).
# Unset all four → local disk volumes (which you must then back up).
R2_ENDPOINT=                   # https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=                     # e.g. luminary-baas-lk
R2_ACCESS_KEY_ID=              # R2 → Manage R2 API Tokens → S3-compatible credentials
R2_SECRET_ACCESS_KEY=
ANTHROPIC_API_KEY=             # chat assistant; unset → assistant returns 503 (disabled)

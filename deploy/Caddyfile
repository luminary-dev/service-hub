# Public edge for the production stack. Caddy auto-provisions and renews TLS
# (Let's Encrypt) for $DOMAIN and reverse-proxies to the web app, which proxies
# /api/* to the gateway on the internal network. No other service is exposed.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# Per-request access logs (#527): Caddy emits none by default. Write them as
	# JSON to stdout so they land in the container's json-file log driver, which
	# is already size-capped + rotated in docker-compose.prod.yml.
	log {
		output stdout
		format json
	}
	encode zstd gzip
	# HSTS: force HTTPS for two years on this host + subdomains. `preload` makes
	# it eligible for the browser preload list (submit the domain separately at
	# hstspreload.org once the site is stable). Caddy already redirects HTTP→HTTPS;
	# this closes the first-request SSL-strip window for the session cookie.
	header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
	reverse_proxy web:3000
}

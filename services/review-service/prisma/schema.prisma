generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// providerId/userId reference rows owned by provider-service and
// identity-service; no FK across service boundaries — existence is checked
// over S2S HTTP at write time, reviewer names hydrated at read time.
model Review {
  id         String   @id @default(cuid())
  providerId String
  userId     String
  rating     Int
  // Optional per-dimension sub-ratings (#528): each 1–5 when the reviewer set
  // it, null when left blank. The overall `rating` above stays AUTHORITATIVE
  // for ranking/sorting — these only feed the profile's rating breakdown and
  // are averaged over their non-null values in the ratings summary.
  quality       Int?
  punctuality   Int?
  value         Int?
  communication Int?
  comment    String
  // Backed by a real interaction (reviewer had inquired with the provider),
  // checked S2S at write time. Evidence for a badge, not a hard gate.
  verified   Boolean  @default(false)
  // Moderation soft delete: set by admin removal, cleared by restore. Public
  // queries filter it; account erasure still hard-deletes regardless.
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  // Last-transition timestamp (#370): auto-stamped on every write (edit,
  // moderation soft-delete/restore) so admins can reason about recency of the
  // last change, not only creation time.
  updatedAt  DateTime @updatedAt
  photos     ReviewPhoto[]
  response   ReviewResponse?

  @@unique([providerId, userId])
  // Matches the provider-profile hot path: filter by providerId, order by
  // (createdAt desc, id desc) with cursor pagination. Lets Postgres range-scan
  // in order instead of sorting every page in memory. Covers plain providerId
  // lookups too (leftmost prefix).
  @@index([providerId, createdAt, id])
  // Account "my reviews" + erase scan by user (#369) — userId is only the 2nd
  // column of the unique above, so unusable as a leading key on its own.
  @@index([userId])
}

// Abuse reports (#50) on reviews — this service owns reviews, so it owns the
// reports on them (provider-service has the same-shaped model for providers
// and work photos). The two models carry the identical field set (#370):
// `source` (USER|SYSTEM) and the `updatedAt` transition timestamp included.
// reporterId references a User owned by identity-service (plain string,
// nullable — anonymous visitors can report). No FK to the target either: a
// report must survive its target being deleted so admins can still see what
// happened.
model Report {
  id         String  @id @default(cuid())
  // "REVIEW"
  targetType String
  targetId   String
  reporterId String?
  // "spam" | "scam" | "offensive" | "fake" | "other" (zod-validated)
  reason     String
  details    String?
  // "OPEN" | "RESOLVED" | "DISMISSED"
  status     String   @default("OPEN")
  // "USER" | "SYSTEM" (#232, reconciled with provider-service in #370): USER
  // reports come from the public report flow; SYSTEM reports are auto-created
  // by the write-time content filter (#375) when a review comment matches the
  // moderation denylist.
  source     String   @default("USER")
  createdAt  DateTime @default(now())
  // Last-transition timestamp (#370): auto-stamped on every write (status
  // resolve/dismiss). Mirrors provider-service's Report.updatedAt.
  updatedAt  DateTime @updatedAt
  // Audit trail (#223): admin userId + timestamp stamped when a report
  // transitions to RESOLVED or DISMISSED. Both null while OPEN.
  resolvedBy String?
  resolvedAt DateTime?

  // Admin queue reads by status; duplicate-protection looks up by target.
  @@index([status])
  @@index([targetType, targetId])
  // Report queue orders newest-first (#369).
  @@index([createdAt])
}

// Provider's public reply to a review (#395): at most one per review
// (reviewId unique), written only by the reviewed profile's owner — ownership
// is checked over S2S at write time (same convention as review creation).
// Cascades with the review; soft-deleted reviews hide it because public
// queries filter the parent.
model ReviewResponse {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())
  // Auto-stamped on edit so the UI can flag an edited response.
  updatedAt DateTime @updatedAt
}

model ReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@index([reviewId])
}

// Moderation audit trail (#227): one row per admin action taken through this
// service's /api/admin/* routes (review delete, report resolve/dismiss).
// adminId references a User owned by identity-service (plain string, no FK —
// same convention as Report.reporterId). provider-service keeps an identical
// model for the moderation actions it owns; the two logs are merged only in
// the admin frontend's combined view, never server-side.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  // The read endpoint filters by any combination of admin/action/date range,
  // and always orders newest-first.
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

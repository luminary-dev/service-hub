generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// providerId/userId reference rows owned by provider-service and
// identity-service; no FK across service boundaries — existence is checked
// over S2S HTTP at write time, reviewer names hydrated at read time.
model Review {
  id         String   @id @default(cuid())
  providerId String
  userId     String
  rating     Int
  comment    String
  // Backed by a real interaction (reviewer had inquired with the provider),
  // checked S2S at write time. Evidence for a badge, not a hard gate.
  verified   Boolean  @default(false)
  // Moderation soft delete: set by admin removal, cleared by restore. Public
  // queries filter it; account erasure still hard-deletes regardless.
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  photos     ReviewPhoto[]

  @@unique([providerId, userId])
  // Matches the provider-profile hot path: filter by providerId, order by
  // (createdAt desc, id desc) with cursor pagination. Lets Postgres range-scan
  // in order instead of sorting every page in memory. Covers plain providerId
  // lookups too (leftmost prefix).
  @@index([providerId, createdAt, id])
}

// Abuse reports (#50) on reviews — this service owns reviews, so it owns the
// reports on them (provider-service has the same-shaped model for providers
// and work photos). reporterId references a User owned by identity-service
// (plain string, nullable — anonymous visitors can report). No FK to the
// target either: a report must survive its target being deleted so admins can
// still see what happened.
model Report {
  id         String  @id @default(cuid())
  // "REVIEW"
  targetType String
  targetId   String
  reporterId String?
  // "spam" | "scam" | "offensive" | "fake" | "other" (zod-validated)
  reason     String
  details    String?
  // "OPEN" | "RESOLVED" | "DISMISSED"
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  // Audit trail (#223): admin userId + timestamp stamped when a report
  // transitions to RESOLVED or DISMISSED. Both null while OPEN.
  resolvedBy String?
  resolvedAt DateTime?

  // Admin queue reads by status; duplicate-protection looks up by target.
  @@index([status])
  @@index([targetType, targetId])
}

model ReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@index([reviewId])
}

// Moderation audit trail (#227): one row per admin action taken through this
// service's /api/admin/* routes (review delete, report resolve/dismiss).
// adminId references a User owned by identity-service (plain string, no FK —
// same convention as Report.reporterId). provider-service keeps an identical
// model for the moderation actions it owns; the two logs are merged only in
// the admin frontend's combined view, never server-side.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  // The read endpoint filters by any combination of admin/action/date range,
  // and always orders newest-first.
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

PORT=4005
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/notification_db
# Direct-to-Postgres connection used ONLY by the Prisma CLI (`migrate deploy`,
# via prisma.config.ts → DIRECT_URL ?? DATABASE_URL, #674). On host dev / CI
# there is no pooler, so leave it unset and the CLI reuses DATABASE_URL. In
# Docker it points straight at Postgres (bypassing PgBouncer) for migrate's
# advisory locks / prepared statements.
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/notification_db
INTERNAL_API_SECRET=dev-internal-secret
RESEND_API_KEY=
EMAIL_FROM=Baas.lk <onboarding@resend.dev>
# Dev SMTP transport (Mailpit, #673). Set → mail is sent over SMTP instead of
# Resend (handy for local testing without a real provider); unset → falls back
# to RESEND_API_KEY, then to logging the message to the console. Production
# leaves this unset and keeps using Resend.
# SMTP_URL=smtp://localhost:1025
# Email delivery queue. Unset → degraded mode: each send is attempted once,
# in-process, best-effort (in-app notifications are unaffected either way).
REDIS_URL=

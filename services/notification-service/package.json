{
  "name": "notification-service",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:migrate": "prisma migrate deploy && exec node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --env-file-if-exists=.env prisma/seed.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/node": "^10.65.0",
    "hono": "^4.12.30",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "pg": "8.22.0",
    "prisma": "7.8.0",
    "prom-client": "^15.1.3",
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.23.1",
    "typescript": "7.0.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  }
}

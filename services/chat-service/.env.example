PORT=4007
INTERNAL_API_SECRET=dev-internal-secret
GATEWAY_URL=http://localhost:4000
# Public web origin used to build absolute links in assistant responses. Falls
# back to the gateway-forwarded `x-origin` header, then to this value, then to
# http://localhost:3000 when unset (src/lib/http.ts).
WEB_ORIGIN=http://localhost:3000
# Required for the assistant to function; unset → 503.

PORT=4000
AUTH_SECRET=dev-only-secret
INTERNAL_API_SECRET=dev-internal-secret
IDENTITY_SERVICE_URL=http://localhost:4001
PROVIDER_SERVICE_URL=http://localhost:4002
REVIEW_SERVICE_URL=http://localhost:4003
JOB_SERVICE_URL=http://localhost:4004
NOTIFICATION_SERVICE_URL=http://localhost:4005
MEDIA_SERVICE_URL=http://localhost:4006
TRUST_SAFETY_SERVICE_URL=http://localhost:4009
WEB_ORIGIN=http://localhost:3000
SEARCH_SERVICE_URL=http://localhost:4008
# Distributed rate-limit window (#117). Unset → per-instance in-memory fallback
# (fine for single-instance dev); set it to share the window across gateway
# instances via Redis. See docs/RATE_LIMITING.md.
# REDIS_URL=redis://localhost:6379
# Trusted reverse-proxy hop count for rate-limit client-IP resolution (#201).
# Default 0 = trust only the socket peer (safe for a directly-exposed gateway).
# In prod the Caddy→web→gateway chain uses 2. See docs/RATE_LIMITING.md.
# TRUSTED_PROXY_HOPS=0

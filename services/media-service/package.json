{
  "name": "media-service",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.30",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "@types/node": "26.1.1",
    "tsx": "^4.23.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Managed service categories (#135/#60). provider-service owns the canonical
// list; siblings read it via GET /internal/categories. No hard delete —
// deactivating (active=false) hides a category from the public list while
// existing providers keep the slug. Provider.category stays a plain string
// (no FK) so historical rows never break.
model Category {
  slug      String  @id
  labelEn   String
  labelSi   String
  icon      String?
  // Optional cover image (#436). Admin-uploaded via media-service (R2 in prod);
  // used as the card cover fallback when a provider has no cover of their own.
  // Distinct from `icon` (a font-awesome component name, not an image).
  imageUrl  String?
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

// userId references a User owned by identity-service; no FK across service
// boundaries. Contact fields are denormalized from the user at registration
// and kept in sync on profile updates (S2S PATCH to identity).
model Provider {
  id           String  @id @default(cuid())
  userId       String  @unique
  contactName  String
  contactEmail String
  contactPhone String?

  category   String
  headline   String
  bio        String
  // Optional Sinhala variants of the free-text pitch (#515). Providers may
  // author their headline/bio in Sinhala as well as English; public rendering
  // prefers the SI variant under the `si` locale and falls back to the English
  // original when absent. Nullable + additive — English stays the required
  // source of truth. Per-service SI titles are a deliberate follow-up.
  headlineSi String?
  bioSi      String?
  district   String
  city       String
  experience Int     @default(0)
  whatsapp   String?
  phone2     String?
  facebook   String?
  instagram  String?
  tiktok     String?
  youtube    String?
  website    String?
  avatarUrl  String?
  // Dedicated cover photo (#435), independent of the work gallery. When set it
  // wins over the first-work-photo derivation for the card cover, so reordering
  // the gallery no longer silently changes the cover.
  coverPhoto String?
  available  Boolean @default(true)
  // Away mode (#49): a provider going on leave sets a return date. Effective
  // availability = available && (awayUntil == null || awayUntil <= now) —
  // centralized in lib/availability.ts — so availability flips back
  // automatically once the date passes; no cron needed.
  awayUntil  DateTime?
  suspended  Boolean @default(false)
  // NONE | PENDING | VERIFIED | REJECTED
  verificationStatus String    @default("NONE")
  verifiedAt         DateTime?
  // Set when an admin rejects a verification request (single or bulk) so the
  // provider knows what to fix on resubmission. Cleared on the next approve.
  rejectionReason    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  services         Service[]
  photos           WorkPhoto[]
  inquiries        Inquiry[]
  verificationDocs VerificationDocument[]

  // Browse filters (category alone uses the leftmost prefix) and newest-first
  // ranking; district-only browsing is a separate path.
  @@index([category, district])
  @@index([district])
  @@index([createdAt])
  // Admin verification queue filters by status (#369).
  @@index([verificationStatus])
}

model VerificationDocument {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  kind       String // "NIC" | "BUSINESS"
  url        String
  createdAt  DateTime @default(now())

  @@index([providerId])
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  price       Float
  priceType   String   @default("FIXED")

  @@index([providerId])
}

model WorkPhoto {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  // Manual gallery position (PATCH /api/provider/photos/order writes the
  // array index). Photo queries order by sortOrder asc, createdAt desc, so
  // fresh uploads (sortOrder 0) surface first until the provider reorders.
  sortOrder  Int      @default(0)
  // Moderation soft delete: set by admin removal, cleared by restore. Public
  // queries filter it; owner deletes and account erasure stay hard.
  deletedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([providerId])
}

// Abuse reports (#50) on content this service owns (providers and work
// photos). Each content-owning service keeps the reports on its own content —
// review-service has the same-shaped model for reviews (#370): both carry the
// identical field set — `source` (USER|SYSTEM) and the `updatedAt` transition
// timestamp included. reporterId references a User owned by identity-service
// (plain string, nullable — anonymous visitors can report). No FK to the
// target either: a report must survive its target being deleted so admins can
// still see what happened.
model Report {
  id         String  @id @default(cuid())
  // "PROVIDER" | "WORK_PHOTO" | "MESSAGE" (inquiry thread messages, #376)
  targetType String
  targetId   String
  reporterId String?
  // "spam" | "scam" | "offensive" | "fake" | "other" (zod-validated)
  reason     String
  details    String?
  // "OPEN" | "RESOLVED" | "DISMISSED"
  status     String   @default("OPEN")
  // "USER" | "SYSTEM" (#232): USER reports come from the public report flow
  // above; SYSTEM reports are auto-created by POST /api/admin/flagging/run
  // when a provider crosses a report-count or rating threshold.
  source     String   @default("USER")
  createdAt  DateTime @default(now())
  // Last-transition timestamp (#370): auto-stamped on every write (status
  // resolve/dismiss, source change), so admins can sort/audit by recency of
  // action rather than only creation.
  updatedAt  DateTime @updatedAt
  // Audit trail (#223): admin userId + timestamp stamped when a report
  // transitions to RESOLVED or DISMISSED. Both null while OPEN.
  resolvedBy String?
  resolvedAt DateTime?

  // Admin queue reads by status; duplicate-protection looks up by target.
  @@index([status])
  @@index([targetType, targetId])
  // Report queue orders newest-first (#369).
  @@index([createdAt])
}

// userId references a User owned by identity-service (plain string, nullable —
// anonymous inquiries are allowed).
model Inquiry {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  userId     String?
  name       String
  phone      String
  email      String?
  message    String
  status     String   @default("NEW")
  // Stamped once, when status first moves to RESPONDED; drives the public
  // profile's average-response-time stat.
  respondedAt DateTime?
  // Where the inquiry came from ("web" form, "chat-agent" for #11) — analytics.
  source      String?
  // Thread read markers (#13): each party's last visit to the thread; unread
  // counts compare these against message timestamps from the other side.
  customerLastReadAt DateTime?
  providerLastReadAt DateTime?
  createdAt   DateTime  @default(now())
  // Last-transition timestamp (#370): auto-stamped on every write (status
  // change, respondedAt stamp, read-marker updates) so the dashboard inbox can
  // reason about recency of activity, not just creation time.
  updatedAt   DateTime  @updatedAt
  messages    InquiryMessage[]

  @@index([providerId])
  // Dashboard inbox filters+sorts by provider then recency (#369).
  @@index([providerId, createdAt])
  // Account history / review-eligibility gate / erase scan by user (#369).
  @@index([userId])
}

// Conversation thread per inquiry (#13). Only signed-in inquiries can thread
// (anonymous inquiries carry no identity to authenticate follow-ups).
model InquiryMessage {
  id        String   @id @default(cuid())
  inquiryId String
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  sender    String // "CUSTOMER" | "PROVIDER"
  body      String
  // Moderation soft delete (#376): set by admin takedown of a reported
  // message, cleared by restore. Thread reads and unread counts filter it;
  // the row survives so the action is reversible and the reports queue can
  // still show what was removed.
  deletedAt DateTime?
  createdAt DateTime @default(now())

  @@index([inquiryId, createdAt])
}

// Moderation audit trail (#227): one row per admin action taken through this
// service's /api/admin/* routes (provider verify/suspend, photo delete,
// report resolve/dismiss, category create/edit). adminId references a User
// owned by identity-service (plain string, no FK — same convention as
// Report.reporterId). review-service keeps an identical model for the
// moderation actions it owns; the two logs are merged only in the admin
// frontend's combined view, never server-side.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  // The read endpoint filters by any combination of admin/action/date range,
  // and always orders newest-first.
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

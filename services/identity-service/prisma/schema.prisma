generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  // Nullable since social-login (#398): an account created via an OAuth
  // provider has no password until the user sets one through the reset flow.
  // Password-based routes (login/change-password/delete-account) guard for
  // null before calling bcrypt.
  passwordHash  String?
  name          String
  phone         String?
  // Role is a plain string, not a Postgres/Prisma enum — there never was a
  // native enum type to extend. Valid values: CUSTOMER, PROVIDER, ADMIN,
  // SUPPORT. The two admin tiers (#226): ADMIN is full access (deletes,
  // category edits, role changes, user management, impersonation); SUPPORT
  // is a limited tier (read access to every admin endpoint + report
  // resolve/dismiss — see src/lib/roles.ts in the web app for the exact
  // gating). There is no separate super-admin tier: ADMIN is the
  // full-access role. A CHECK constraint enforcing this set is maintained
  // by the migrations under prisma/migrations (20260707130000_admin_role_tiers
  // added it; 20260708200000_drop_superadmin_role narrowed it to the four
  // values above), not represented here since it isn't diffed by
  // `prisma migrate dev` in this project (migrations are hand-written).
  role          String    @default("CUSTOMER")
  emailVerified DateTime?
  // Session revocation: tokens carry the version they were minted with (sv
  // claim); a bump (password change/reset, logout-everywhere) invalidates
  // every older token.
  sessionVersion Int      @default(0)
  // Per-account lockout: wrong passwords increment failedLogins; at the
  // threshold the account locks for a window. Successful login resets both.
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  favorites     Favorite[]

  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  accounts                Account[]
}

// Linked social identities (#398). One row per (provider, providerAccountId);
// a user may hold several (e.g. password + Google). Kept in identity-service
// because it owns the User row and is the sole minter of the session JWT.
model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // OAuth provider key, e.g. "google". Not an enum — same rationale as
  // User.role (migrations are hand-written; no native enum to extend).
  provider          String
  // The provider's stable subject id for this user (Google `sub`). Never the
  // email, which can change and be reassigned.
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Minimal audit trail for self-service account deletion (#123): who was
// erased and when. Deliberately survives the User row (no relation).
model AccountDeletion {
  id        String   @id @default(cuid())
  userId    String
  email     String
  role      String
  createdAt DateTime @default(now())
}

// Standalone log for admin impersonation ("view as", #234): who impersonated
// whom and for how long. Deliberately minimal and separate from the general
// moderation audit log proposed in #227 — once that lands this should be
// reconciled/merged into it rather than kept as a second audit trail.
// No relations to User: an impersonation record should survive account
// deletion of either party, same rationale as AccountDeletion above.
model ImpersonationLog {
  id           String    @id @default(cuid())
  adminId      String
  targetUserId String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?

  @@index([adminId])
  @@index([targetUserId])
}

// providerId references a Provider owned by provider-service; no FK across
// service boundaries — existence is checked over S2S HTTP at write time.
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String
  createdAt  DateTime @default(now())

  @@unique([userId, providerId])
  @@index([userId])
  @@index([providerId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("CUSTOMER")
  emailVerified DateTime?
  // Session revocation: tokens carry the version they were minted with (sv
  // claim); a bump (password change/reset, logout-everywhere) invalidates
  // every older token.
  sessionVersion Int      @default(0)
  // Per-account lockout: wrong passwords increment failedLogins; at the
  // threshold the account locks for a window. Successful login resets both.
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  favorites     Favorite[]

  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

// Minimal audit trail for self-service account deletion (#123): who was
// erased and when. Deliberately survives the User row (no relation).
model AccountDeletion {
  id        String   @id @default(cuid())
  userId    String
  email     String
  role      String
  createdAt DateTime @default(now())
}

// Standalone log for admin impersonation ("view as", #234): who impersonated
// whom and for how long. Deliberately minimal and separate from the general
// moderation audit log proposed in #227 — once that lands this should be
// reconciled/merged into it rather than kept as a second audit trail.
// No relations to User: an impersonation record should survive account
// deletion of either party, same rationale as AccountDeletion above.
model ImpersonationLog {
  id           String    @id @default(cuid())
  adminId      String
  targetUserId String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?

  @@index([adminId])
  @@index([targetUserId])
}

// providerId references a Provider owned by provider-service; no FK across
// service boundaries — existence is checked over S2S HTTP at write time.
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String
  createdAt  DateTime @default(now())

  @@unique([userId, providerId])
  @@index([userId])
  @@index([providerId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

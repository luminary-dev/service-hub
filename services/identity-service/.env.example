PORT=4001
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/identity_db
AUTH_SECRET=dev-only-secret
INTERNAL_API_SECRET=dev-internal-secret
PROVIDER_SERVICE_URL=http://localhost:4002
NOTIFICATION_SERVICE_URL=http://localhost:4005
# Social login (#398). Unset → "Continue with Google" is disabled (password auth
# still works). Register redirect URI http://localhost:3000/api/auth/oauth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook Login (#398). Same as Google; register redirect URI
# http://localhost:3000/api/auth/oauth/facebook/callback in Meta for Developers.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

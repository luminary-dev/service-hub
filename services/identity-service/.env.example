PORT=4001
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/identity_db
# Direct-to-Postgres connection used ONLY by the Prisma CLI (`migrate deploy`,
# via prisma.config.ts → DIRECT_URL ?? DATABASE_URL, #674). On host dev / CI
# there is no pooler, so leave it unset and the CLI reuses DATABASE_URL. In
# Docker it points straight at Postgres (bypassing PgBouncer) for migrate's
# advisory locks / prepared statements.
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/identity_db
AUTH_SECRET=dev-only-secret
INTERNAL_API_SECRET=dev-internal-secret
PROVIDER_SERVICE_URL=http://localhost:4002
REVIEW_SERVICE_URL=http://localhost:4003
JOB_SERVICE_URL=http://localhost:4004
MEDIA_SERVICE_URL=http://localhost:4006
NOTIFICATION_SERVICE_URL=http://localhost:4005
# Session-revocation publish (#374). Unset → the gateway falls back to its S2S
# identity lookup for revocation checks (fail-open); set it to share the Redis
# revocation list. Same Redis instance/URL as the gateway.
# REDIS_URL=redis://localhost:6379
# Social login (#398). Unset → "Continue with Google" is disabled (password auth
# still works). Register redirect URI http://localhost:3000/api/auth/oauth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook Login (#398). Same as Google; register redirect URI
# http://localhost:3000/api/auth/oauth/facebook/callback in Meta for Developers.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Cloudflare Turnstile secret key (#633) — optional bot protection on
# registration. Unset (the default) → verification is skipped and registration
# behaves as before; set it to require a valid widget token (verified via
# siteverify). Pair it with NEXT_PUBLIC_TURNSTILE_SITE_KEY on the web app.
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile.
TURNSTILE_SECRET_KEY=

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// customerId references a User owned by identity-service; providerId
// references a Provider owned by provider-service. No FKs across service
// boundaries — existence is checked over S2S HTTP at write time and names
// are hydrated at read time.
model JobRequest {
  id          String        @id @default(cuid())
  customerId  String
  category    String
  district    String
  title       String
  description String
  budget      Int? // optional, LKR
  status      String        @default("OPEN") // OPEN | CLOSED
  createdAt   DateTime      @default(now())
  // Last-transition timestamp (#370): auto-stamped on every write (edit, the
  // OPEN→CLOSED transition) so listings can reason about recency of the last
  // change, not only creation time.
  updatedAt   DateTime      @updatedAt
  responses   JobResponse[]

  @@index([category, district, status])
  @@index([customerId])
  // Admin job list (#521) orders by createdAt desc with an optional bare
  // status filter and no category/district — the [category, district, status]
  // index can't serve a status-only predicate or plain createdAt ordering
  // (category is leftmost). A lone createdAt index serves the unfiltered
  // ordering; [status, createdAt] serves the status-filtered variant (equality
  // on status, then an ordered scan on createdAt).
  @@index([createdAt])
  @@index([status, createdAt])
}

model JobResponse {
  id           String     @id @default(cuid())
  jobRequestId String
  jobRequest   JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  providerId   String
  message      String
  createdAt    DateTime   @default(now())

  @@unique([jobRequestId, providerId])
  @@index([providerId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// customerId references a User owned by identity-service; providerId
// references a Provider owned by provider-service. No FKs across service
// boundaries — existence is checked over S2S HTTP at write time and names
// are hydrated at read time.
model JobRequest {
  id          String        @id @default(cuid())
  customerId  String
  category    String
  district    String
  title       String
  description String
  budget      Int? // optional, LKR
  status      String        @default("OPEN") // OPEN | CLOSED
  // Admin takedown (#376): set when a full admin hides a reported job, cleared
  // on unhide. Hidden jobs disappear from the provider board and stop
  // accepting responses; the row survives so the action is reversible and the
  // admin view can still show what was taken down.
  hiddenAt    DateTime?
  createdAt   DateTime      @default(now())
  // Last-transition timestamp (#370): auto-stamped on every write (edit, the
  // OPEN→CLOSED transition) so listings can reason about recency of the last
  // change, not only creation time.
  updatedAt   DateTime      @updatedAt
  responses   JobResponse[]

  @@index([category, district, status])
  @@index([customerId])
  // Admin job list (#521) orders by createdAt desc with an optional bare
  // status filter and no category/district — the [category, district, status]
  // index can't serve a status-only predicate or plain createdAt ordering
  // (category is leftmost). A lone createdAt index serves the unfiltered
  // ordering; [status, createdAt] serves the status-filtered variant (equality
  // on status, then an ordered scan on createdAt).
  @@index([createdAt])
  @@index([status, createdAt])
}

model JobResponse {
  id           String     @id @default(cuid())
  jobRequestId String
  jobRequest   JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  providerId   String
  message      String
  createdAt    DateTime   @default(now())

  @@unique([jobRequestId, providerId])
  @@index([providerId])
}

// Abuse reports (#376) on content this service owns (job posts). Each
// content-owning service keeps the reports on its own content —
// provider-service and review-service carry the identical field set.
// reporterId references a User owned by identity-service (plain string,
// nullable — anonymous visitors can report). No FK to the target either: a
// report must survive its target being deleted so admins can still see what
// happened.
model Report {
  id         String  @id @default(cuid())
  // "JOB"
  targetType String
  targetId   String
  reporterId String?
  // "spam" | "scam" | "offensive" | "fake" | "other" (zod-validated)
  reason     String
  details    String?
  // "OPEN" | "RESOLVED" | "DISMISSED"
  status     String   @default("OPEN")
  // "USER" | "SYSTEM": USER reports come from the public report flow; SYSTEM
  // is reserved for auto-created reports. Jobs currently only ever produce
  // USER reports, so this defaults to "USER" and the create path leaves it
  // unset (mirrors review-service).
  source     String   @default("USER")
  createdAt  DateTime @default(now())
  // Last-transition timestamp: auto-stamped on every write (status
  // resolve/dismiss). Mirrors provider/review-service's Report.updatedAt.
  updatedAt  DateTime @updatedAt
  // Audit trail: admin userId + timestamp stamped when a report transitions
  // to RESOLVED or DISMISSED. Both null while OPEN.
  resolvedBy String?
  resolvedAt DateTime?

  // Admin queue reads by status; duplicate-protection looks up by target.
  @@index([status])
  @@index([targetType, targetId])
  // Report queue orders newest-first.
  @@index([createdAt])
}

// Moderation audit trail (#376): one row per admin action taken through this
// service's /api/admin/* routes (job hide/unhide, report resolve/dismiss).
// adminId references a User owned by identity-service (plain string, no FK —
// same convention as Report.reporterId). provider-service and review-service
// keep identical models for the actions they own; the logs are merged only in
// the admin frontend's combined view, never server-side.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  // The read endpoint filters by any combination of admin/action/date range,
  // and always orders newest-first.
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}
